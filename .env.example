# Backend API base URL (NestJS - this is the single backend)
VITE_BACKEND_URL=http://localhost:3003/

# FastAPI – used for interview service
VITE_FASTAPI_BASE_URL=http://localhost:8001/api/v1

# Optional: override payment API host (normally keep same as VITE_BACKEND_URL)
# Example: http://localhost:3003/
# VITE_PAYMENT_API_URL=

# OAuth (optional)
# VITE_GOOGLE_CLIENT_ID=
# VITE_GITHUB_CLIENT_ID=

# Landing assets (optional)
# VITE_VIDEO_SRC1=
# VITE_VIDEO_SRC2=
# VITE_VIDEO_SRC3=
